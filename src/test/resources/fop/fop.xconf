<?xml version="1.0" encoding="UTF-8"?>
<!--
  Test-only FOP configuration.
  Uses auto-detected system fonts only — no Thai font embedding.
  This prevents font-not-found failures on developer machines and CI
  where THSarabunNew / NotoSansThai files are not installed.
-->
<fop version="1.0">
    <strict-configuration>false</strict-configuration>
    <strict-validation>false</strict-validation>

    <source-resolution>96</source-resolution>
    <target-resolution>96</target-resolution>

    <default-page-settings height="297mm" width="210mm"/>

    <renderers>
        <renderer mime="application/pdf">
            <version>1.4</version>
            <!-- No pdf-a-mode here: keep test PDF generation simple/fast -->
            <fonts>
                <auto-detect/>
            </fonts>
        </renderer>
    </renderers>
</fop>
